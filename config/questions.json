[
    {
        "id":"report-question-name",
        "name":"Your Name",
        "type":"short",
        
        "required":true,
        "placeholder":"e.g. Cookies are Yummy!",
        "length":{
            "enabled":true,
            "min":2,
            "max":100
        }
    },
    {
        "id":"report-question-type",
        "name":"Type of Issue",
        "type":"short",
        
        "required":true,
        "placeholder":"e.g. Bug, User behaviour, Server issue...",
        "length":{
            "enabled":true,
            "min":3,
            "max":100
        }
    },
    {
        "id":"report-question-description",
        "name":"Describe the Issue 🦉",
        "type":"paragraph",
        
        "required":true,
        "placeholder":"What happened? When did it occur? Any details help!",
        "length":{
            "enabled":true,
            "min":20,
            "max":1000
        }
    },
    {
        "id":"report-question-evidence",
        "name":"Evidence or Extra Context (optional) 🔎",
        "type":"paragraph",
        
        "required":false,
        "placeholder":"Links, usernames, timestamps — anything that might help!",
        "length":{
            "enabled":true,
            "min":0,
            "max":1000
        }
    }
